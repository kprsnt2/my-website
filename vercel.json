{
  "version": 2,
  "builds": [
    {
      "src": "api/interview.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "vercel.app",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/interview",
      "dest": "api/interview.py"
    },
    {
      "src": "/(.*)",
      "dest": "vercel.app"
    }
  ]
}